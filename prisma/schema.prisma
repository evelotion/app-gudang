generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Kategori {
  id          Int      @id @default(autoincrement())
  nama        String   @unique
  deskripsi   String?
  barang      Barang[]
}

model Barang {
  id          String   @id @default(uuid())
  kode_barang String   @unique
  nama_barang String
  satuan      String
  stok        Int      @default(0)
  
  kategoriId  Int
  kategori    Kategori @relation(fields: [kategoriId], references: [id])
  
  transaksi   RequisitionDetail[]
  inbound     InboundDetail[] // <--- TAMBAHIN BARIS INI BRO

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RequisitionHeader {
  id                String   @id @default(uuid())
  media_request     String
  no_dokumen        String   @unique
  tanggal_dokumen   DateTime
  cabang            String
  tanggal_request   DateTime
  jenis_permintaan  String
  pic_nama          String
  keterangan        String?
  
  items             RequisitionDetail[]

  createdAt         DateTime @default(now())
}

model RequisitionDetail {
  id             String            @id @default(uuid())
  qty_diambil    Int
  
  requisitionId  String
  requisition    RequisitionHeader @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  
  barangId       String
  barang         Barang            @relation(fields: [barangId], references: [id])
}

model User {
  id       String   @id @default(uuid())
  inisial  String   @unique
  nama     String
  password String
  
  createdAt DateTime @default(now())
}

model InboundHeader {
  id              String   @id @default(uuid())
  no_dokumen      String   @unique // No PO / Surat Jalan / Nota
  tanggal_masuk   DateTime
  supplier        String
  penerima        String
  keterangan      String?
  
  items           InboundDetail[]

  createdAt       DateTime @default(now())
}

model InboundDetail {
  id             String        @id @default(uuid())
  qty_masuk      Int
  
  inboundId      String
  inbound        InboundHeader @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  
  barangId       String
  barang         Barang        @relation(fields: [barangId], references: [id])
}