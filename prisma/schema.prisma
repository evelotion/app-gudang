generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  inisial   String   @unique
  nama      String
  password  String
  role      String   @default("STAF") // ADMIN atau STAF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kategori {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  deskripsi String?
  barang    Barang[]
}

model Barang {
  id           String   @id @default(cuid())
  kode_barang  String   @unique
  nama_barang  String
  satuan       String
  stok         Int      @default(0)
  
  // Kolom Penyesuaian Laporan Bank
  nomorator    String?
  stok_min     Int      @default(0)
  harga_satuan Float    @default(0)
  supplier     String?
  
  // Relasi ke Kategori (Dibuat opsional agar data lama tidak error)
  kategoriId   Int?
  kategori     Kategori? @relation(fields: [kategoriId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requisitionItems RequisitionDetail[]
  inboundItems     InboundDetail[]
}

model RequisitionHeader {
  id               String   @id @default(cuid())
  media_request    String
  no_dokumen       String   @unique
  tanggal_dokumen  DateTime
  cabang           String
  tanggal_request  DateTime
  jenis_permintaan String
  pic_nama         String
  
  // TAMBAHAN BARU: Status Pengiriman
  status           String   @default("PACKING") // "PACKING" atau "DIKIRIM"
  
  createdAt        DateTime @default(now())
  
  items            RequisitionDetail[]
}

model RequisitionDetail {
  id                  String @id @default(cuid())
  requisitionHeaderId String
  barangId            String
  qty_diambil         Int
  
  header RequisitionHeader @relation(fields: [requisitionHeaderId], references: [id], onDelete: Cascade)
  barang Barang            @relation(fields: [barangId], references: [id])
}

model InboundHeader {
  id            String   @id @default(cuid())
  no_dokumen    String   @unique
  tanggal_masuk DateTime
  supplier      String
  penerima      String
  keterangan    String?
  createdAt     DateTime @default(now())
  
  items         InboundDetail[]
}

model InboundDetail {
  id              String @id @default(cuid())
  inboundHeaderId String
  barangId        String
  qty_masuk       Int
  
  header InboundHeader @relation(fields: [inboundHeaderId], references: [id], onDelete: Cascade)
  barang Barang        @relation(fields: [barangId], references: [id])
}

// ==========================================
// MODUL MANAJEMEN ASET
// ==========================================

model RegistrasiAset {
  id                  String   @id @default(cuid())
  tanggalInput        DateTime @default(now()) // <--- TAMBAHAN UNTUK BATCH DATE
  nomorRegisterAset   String   @unique
  namaAset            String
  golonganAset        String
  jumlah              Int
  tanggalPerolehan    DateTime
  hargaPerolehan      Decimal  @db.Decimal(15, 2)
  cabangUnitKerja     String
  userPengguna        String
  lokasiPosisiAset    String
  
  // Track Records
  status              String   @default("PENDING") // PENDING, APPROVED, REJECTED
  inputerName         String   
  supervisorName      String?  
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HapusBukuAset {
  id                  String   @id @default(cuid())
  tanggalInput        DateTime @default(now()) // <--- TAMBAHAN UNTUK BATCH DATE
  tanggalHapusBuku    DateTime
  nomorRegisterAset   String   
  namaAset            String
  golonganAset        String
  jumlah              Int
  tanggalPerolehan    DateTime
  hargaPerolehan      Decimal  @db.Decimal(15, 2)
  akmPenyusutan       Decimal  @db.Decimal(15, 2)
  nilaiBuku           Decimal  @db.Decimal(15, 2)
  cabangUnitKerja     String
  alasanHapusBuku     String
  
  // Track Records
  status              String   @default("PENDING")
  operatorName        String
  supervisorName      String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
model MutasiAset {
  id                  String   @id @default(cuid())
  tanggalInput        DateTime @default(now())
  tanggalMutasi       DateTime
  nomorRegisterAset   String   
  namaAset            String
  golonganAset        String
  jumlah              Int
  tanggalPerolehan    DateTime
  hargaPerolehan      Decimal  @db.Decimal(15, 2)
  akmPenyusutan       Decimal  @db.Decimal(15, 2)
  lokasiAwal          String
  lokasiTujuan        String
  alasanMutasi        String
  
  // Track Records
  status              String   @default("PENDING")
  operatorName        String
  supervisorName      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}